<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Abyss | Roadmap Generator</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-gray-100 h-screen overflow-hidden flex flex-col font-sans">

    <div class="bg-gray-900 p-6 border-b border-gray-800 shadow-xl z-20">
        <div class="max-w-6xl mx-auto flex items-center justify-between">
            <h1 class="text-3xl font-black text-red-600 tracking-tighter">ABYSS.RDMP</h1>
            <div class="flex gap-2 w-1/2">
                <input type="text" id="roadmapTopic" placeholder="e.g., MERN Stack Career or How to push to GitHub" 
                    class="w-full px-5 py-3 bg-gray-800 border border-gray-700 rounded-xl focus:outline-none focus:border-red-500 transition shadow-inner">
                <button onclick="generateRoadmap()" id="genBtn" 
                    class="bg-red-600 hover:bg-red-700 text-white px-8 py-3 rounded-xl font-bold transition shadow-lg shadow-red-500/20">
                    Generate
                </button>
            </div>
            <a href="/" class="text-sm text-gray-500 hover:text-white transition">Back to Tutor</a>
        </div>
    </div>

    <div class="flex-1 flex overflow-hidden">
        
        <div class="w-1/3 bg-gray-900 border-r border-gray-800 overflow-y-auto p-4 space-y-3" id="stepList">
            <div class="text-center mt-20 text-gray-600">
                <p>Enter a topic above to generate a path.</p>
            </div>
        </div>

        <div class="w-2/3 bg-gray-950 p-12 overflow-y-auto" id="stepDetails">
            <div class="h-full flex flex-col items-center justify-center text-gray-700">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mb-4 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                </svg>
                <p class="text-xl font-medium">Your interactive roadmap will appear here.</p>
            </div>
        </div>
    </div>

    <script>
        let fullRoadmap = [];

        async function generateRoadmap() {
            const topic = document.getElementById('roadmapTopic').value;
            const genBtn = document.getElementById('genBtn');
            const stepList = document.getElementById('stepList');
            const stepDetails = document.getElementById('stepDetails');

            if (!topic) return alert("Please enter a topic!");

            // Loading State
            genBtn.innerText = "Architecting...";
            genBtn.disabled = true;
            stepList.innerHTML = `<div class="animate-pulse space-y-4 p-4">
                <div class="h-12 bg-gray-800 rounded"></div>
                <div class="h-12 bg-gray-800 rounded"></div>
                <div class="h-12 bg-gray-800 rounded"></div>
            </div>`;

            try {
                const response = await fetch('/api/v1/roadmap/generate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ topic })
                });

                const result = await response.json();

                if (result.success) {
                    fullRoadmap = result.steps;
                    renderSidebar();
                    showStep(0); // Show first step by default
                } else {
                    alert("Error: " + result.message);
                }
            } catch (err) {
                alert("Server connection failed.");
            } finally {
                genBtn.innerText = "Generate";
                genBtn.disabled = false;
            }
        }

        function renderSidebar() {
            const stepList = document.getElementById('stepList');
            stepList.innerHTML = `<h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-4 px-2">Path Milestones</h3>`;
            
            fullRoadmap.forEach((item, index) => {
                const btn = document.createElement('button');
                btn.className = `w-full text-left p-4 rounded-xl transition flex items-center gap-4 group hover:bg-gray-800 active:scale-95`;
                btn.onclick = () => showStep(index);
                btn.innerHTML = `
                    <div class="w-8 h-8 rounded-full bg-gray-800 flex items-center justify-center text-xs font-bold border border-gray-700 group-hover:border-red-500 transition">
                        ${item.step}
                    </div>
                    <div class="font-semibold text-gray-300 group-hover:text-white">${item.title}</div>
                `;
                stepList.appendChild(btn);
            });
        }

        function showStep(index) {
            const data = fullRoadmap[index];
            const stepDetails = document.getElementById('stepDetails');

            stepDetails.innerHTML = `
                <div class="max-w-3xl animate-fadeIn">
                    <span class="text-red-500 font-bold text-sm uppercase tracking-widest">Step ${data.step}</span>
                    <h2 class="text-5xl font-black mt-2 mb-6">${data.title}</h2>
                    <p class="text-gray-400 text-xl leading-relaxed mb-8">${data.description}</p>
                    
                    ${data.command ? `
                        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-8 relative group">
                            <div class="text-xs text-gray-600 mb-2 font-mono uppercase">Execution Script / Command</div>
                            <code class="text-green-400 font-mono text-lg">${data.command}</code>
                        </div>
                    ` : ''}

                    <div class="mt-12">
                        <h4 class="text-sm font-bold text-gray-500 uppercase mb-4">Recommended for this step:</h4>
                        <a href="https://www.youtube.com/results?search_query=${encodeURIComponent(data.videoQuery)}" target="_blank" 
                           class="flex items-center gap-4 p-4 bg-gray-900 border border-gray-800 rounded-2xl hover:border-red-500 transition group">
                            <div class="w-16 h-12 bg-red-600/20 rounded-lg flex items-center justify-center text-red-500">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <div>
                                <div class="font-bold">Tutorial Search: ${data.videoQuery}</div>
                                <div class="text-xs text-gray-500">Click to find the best video in Abyss</div>
                            </div>
                        </a>
                    </div>
                </div>
            `;
        }
    </script>

    <style>
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fadeIn { animation: fadeIn 0.4s ease-out forwards; }
    </style>
</body>
</html>